# Copy to .env and fill in for production. Defaults run a seeded Dublin demo with no creds.

DEBUG=true

# Data backend: "postgres" (operational DB) | "memory" (seeded demo) | "airtable"
DB_BACKEND=postgres

# Postgres (DB_BACKEND=postgres). Async URL via asyncpg. Omit user → OS user (local peer auth).
DATABASE_URL=postgresql+asyncpg://localhost:5432/raddar

# Airtable (legacy; only when DB_BACKEND=airtable)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Events

# Launch city (Dublin defaults baked into config.py; override only if needed)
# CITY_NAME=Dublin
# TIMEZONE=Europe/Dublin
# ANCHOR_LAT=53.3498
# ANCHOR_LNG=-6.2603

# Ingestion pipeline sources (leave blank → uses the bundled Dublin fixture)
EVENTBRITE_TOKEN=
EVENTBRITE_ORGANIZATION_ID=
PREDICTHQ_TOKEN=
FIRECRAWL_API_KEY=
# Geocoding for scraped events (address → coords). Without it, address-only events are rejected.
GOOGLE_GEOCODING_KEY=
PIPELINE_INTERVAL_SECONDS=300
